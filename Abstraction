// abstraction class and method
package task2;
abstract class animal{
	abstract void sound();
	void sleeping() {
		System.out.println("animal is sleeping");
	}
	
}
class dog extends animal{
	public void sound() {
		System.out.println("bow bow");
	}
	
}

public class abstract1 {

	public static void main(String[] args) {
		dog d = new dog();
		d.sound();
		d.sleeping();

	}

}
// interface 
package task2;
interface readable{
	void read();
		
	}
	

interface writable{
	void write();
	
}
interface storable 
{
	void store();
	
}
class file implements storable, writable, readable
{
	public void read() {
		System.out.println("read the file");
		
	}
	public void write() {
		System.out.println("read the file");
	}
	public void store() {
		System.out.println("store the file");
	}
	
}
public class interface1 {

	public static void main(String[] args) {
		file  f = new file();
		f.read();
		f.write();
		f.store();
		

	}

}
