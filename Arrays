package practice;

public class even_odd_countarrays {

	public static void main(String[] args) {
		int a[] = {7,4,5,6,2,9};
		int eventcount = 0;
		int oddcount = 0;
		for(int i=0;i<a.length;i++) {
			if(a[i]%2==0) {
				eventcount++;
				
				
			}else {
				oddcount++;
			
			
		}
		
		

	}
		System.out.println("event count is "+ eventcount);
		System.out.println("oddcount is "+ oddcount);
	

	}
}
